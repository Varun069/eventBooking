{
  "info": {
    "name": "Event Booking System",
    "description": "Lattice Innovations — Junior Node.js Selection Test",
    "_postman_id": "event-booking-lattice-2026",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" }
  ],
  "item": [
    {
      "name": "Events",
      "item": [
        {
          "name": "List Upcoming Events",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/events", "host": ["{{base_url}}"], "path": ["events"] },
            "description": "Returns all future events ordered by date."
          }
        },
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/events", "host": ["{{base_url}}"], "path": ["events"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Node.js Workshop\",\n  \"description\": \"Hands-on session for beginners\",\n  \"date\": \"2026-04-15T10:00:00.000Z\",\n  \"capacity\": 50\n}"
            },
            "description": "Creates a new event."
          }
        },
        {
          "name": "Record Attendance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/events/1/attendance",
              "host": ["{{base_url}}"],
              "path": ["events", "1", "attendance"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_code\": \"REPLACE_WITH_ACTUAL_UUID\"\n}"
            },
            "description": "Check in using a booking code. Returns total tickets booked for the event."
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Book a Ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"event_id\": 1\n}"
            },
            "description": "Books a ticket. Uses a transaction with SELECT FOR UPDATE to prevent overselling. Returns unique booking_code."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User Bookings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users/1/bookings",
              "host": ["{{base_url}}"],
              "path": ["users", "1", "bookings"]
            },
            "description": "Returns all bookings made by user with ID 1, including check-in status."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        }
      ]
    }
  ]
}
